############# Step 15: Auto-generate the methods paragraph #############

# Capture tool versions
rule versions_fastp:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/fastp.txt"
    conda: "envs/fastp.yml"
    shell:
        """
        # fastp prints the version to stderr and returns a '2' exit code.
        # kind of annoying. so we swallow the non-zero exit code here,
        # otherwise snakemake will think the step failed.
        fastp --version > {output} 2>&1 || true
        """

rule versions_fastqc:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/fastqc.txt"
    conda: "envs/fastqc.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/fastqc.log"
    shell:
        """
        fastqc --version > {output} 2>> {log}
        """

rule versions_multiqc:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/multiqc.txt"
    conda: "envs/multiqc.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/multiqc.log"
    shell:
        """
        multiqc --version > {output} 2>> {log}
        """

rule versions_rsem:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output:
        rsem=STEP_PROSE_DIR + "versions/rsem.txt",
        star=STEP_PROSE_DIR + "versions/star.txt",
    conda: "envs/rsem.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/rsem_star.log"
    shell:
        """
        rsem-calculate-expression --version > {output.rsem} 2>> {log}
        STAR --version >> {output.star} 2>> {log}
        """

rule versions_picard:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/picard.txt"
    conda: "envs/qc_report.yml"
    shell:
        """
        # Picard prints its version to stderr and exits non-zero, so swallow the
        # exit code (as with fastp) to keep snakemake from flagging a failure.
        picard CollectRnaSeqMetrics --version > {output} 2>&1 || true
        """

rule versions_tximport:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/tximport.txt"
    conda: "envs/tximport.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/tximport.log"
    shell:
        """
        Rscript -e 'cat(sprintf("tximport=%s\\n", as.character(packageVersion("tximport"))));' > {output} 2>> {log}
        """

rule versions_deseq2:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/deseq2.txt"
    conda: "envs/deseq2.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/deseq2.log"
    shell:
        """
        Rscript -e 'cat(sprintf("deseq2=%s\\n", as.character(packageVersion("DESeq2"))));' > {output} 2>> {log}
        """

rule versions_gsva_limma:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output:
        gsva=STEP_PROSE_DIR + "versions/gsva.txt",
        limma=STEP_PROSE_DIR + "versions/limma.txt",
    conda: "envs/gsva_limma.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/gsva_limma.log"
    shell:
        """
        Rscript -e 'cat(sprintf("gsva=%s\\n", as.character(packageVersion("GSVA"))));' > {output.gsva} 2>> {log}
        Rscript -e 'cat(sprintf("limma=%s\\n", as.character(packageVersion("limma"))));' > {output.limma} 2>> {log}
        """

rule versions_fgsea:
    input: scores=STEP_GSVA_DIR + "gsva_scores.csv", # not used; only for linear DAG
    output: STEP_PROSE_DIR + "versions/fgsea.txt"
    conda: "envs/gsea.yml"
    log: LOGS + Path(STEP_PROSE_DIR).name + "/versions/fgsea.log"
    shell:
        """
        Rscript -e 'cat(sprintf("fgsea=%s\\n", as.character(packageVersion("fgsea"))));' > {output} 2>> {log}
        """

# write the methods paragraph
rule prose:
    input:
        script="scripts/prose.py",
        versions=expand(STEP_PROSE_DIR + "versions/{env}.txt", env=VERSION_ENVS),
        gsea=expand(STEP_GSEA_DIR + "{contrast}.csv", contrast=CONTRAST_NAMES), # not used; only for linear DAG
    output:
        STEP_PROSE_DIR + "methods.md",
    params:
        versions_dir=STEP_PROSE_DIR + "versions",
        exclude=EXCLUDE_CSV_PATH,
        min_count=config["filter"]["min_count"],
        min_samples=config["filter"]["min_samples"],
        fasta=GENOME_FASTA,
        gtf=GTF,
    log:
        LOGS + Path(STEP_PROSE_DIR).name + "/methods.log"
    shell:
        """
        python {input.script} \
            --versions-dir {params.versions_dir} \
            --exclude "{params.exclude}" \
            --min-count {params.min_count} \
            --min-samples {params.min_samples} \
            --fasta {params.fasta} \
            --gtf {params.gtf} \
            --out {output} \
            &> {log}
        """

############# Step 16: Exploratory plots (heatmaps, volcano, etc.) #############



############# Last step: Re-generate user-defined Quarto reports #############
rule render_quarto:
    input:
        qmd_path=REPORTS_DIR + "{dir_name}/{qmd_name}.qmd",
        methods=STEP_PROSE_DIR + "methods.md", # not used; runs Quarto as the last step
    output:
        STEP_QUARTO_DIR + "{dir_name}/{qmd_name}.html",
    conda:
        "envs/quarto.yml"
    log:
        LOGS + Path(STEP_QUARTO_DIR).name + "/{dir_name}/{qmd_name}.log",
    shell:
        # Quarto writes the rendered HTML next to the source .qmd; move it into
        # the results reports dir so it matches the declared output. (Quarto's
        # --output-dir is resolved relative to the input file, so it can't be
        # pointed straight at an arbitrary results path.)
        """
        quarto render {input.qmd_path} -M embed-resources:true &> {log}
        mkdir -p "$(dirname {output})"
        mv "$(dirname {input.qmd_path})/{wildcards.qmd_name}.html" "{output}"
        """